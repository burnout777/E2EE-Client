<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="chatRoot" prefHeight="800.0" prefWidth="1200.0"
            style="-fx-background-color: #050505;"
            stylesheets="@../css/chat.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.client.controller.ChatController">

    <left>
        <VBox prefWidth="220" style="-fx-border-color: #111; -fx-border-width: 0 1 0 0;">
            <StackPane fx:id="newChannelContainer">
                <Button fx:id="newChannelBtn" text="[ + NEW CHANNEL ]" onAction="#handleNewChat"
                        style="-fx-padding: 15;"/>
            </StackPane>

            <Label text="ACTIVE_NODES" styleClass="dim"
                   style="-fx-padding: 5 15; -fx-font-size: 9px;"/>

            <ListView fx:id="contactList" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: #050505; -fx-control-inner-background: #050505;"/>
        </VBox>
    </left>

    <center>
        <VBox>
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 15; -fx-border-color: #111; -fx-border-width: 0 0 1 0;">
                <Label fx:id="activeChatLabel" text="NO ACTIVE CONNECTIONS" style="-fx-font-size: 14px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="[ ⚙ SETTINGS ]" onAction="#handleOpenSettings"
                />
            </HBox>

            <ListView fx:id="messageArea" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: #050505; -fx-control-inner-background: #050505;"/>

            <HBox alignment="CENTER" style="-fx-padding: 20;">
                <TextField fx:id="messageInput" HBox.hgrow="ALWAYS"
                           promptText="TYPE ENCRYPTED PACKET..." onAction="#handleSendMessage"
                           style="-fx-background-color: transparent; -fx-text-fill: white;
                                  -fx-prompt-text-fill: #222; -fx-border-color: #333;
                                  -fx-border-width: 1 0 0 0; -fx-font-family: 'Monospaced';
                                  -fx-font-size: 15;
                                  -fx-padding: 10 0 10 0;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>